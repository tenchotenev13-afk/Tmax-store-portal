<!DOCTYPE html>
<html lang="bg">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ТЕМАКС Портал</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap');
:root{
  --c1:#0f172a;--c2:#1e293b;--c3:#334155;--c4:#64748b;--c5:#94a3b8;
  --border:#e2e8f0;--text:#0f172a;--muted:#64748b;--surf:#f8fafc;
  --grn:#16a34a;--grn-bg:#f0fdf4;--grn-b:#bbf7d0;
  --blu:#2563eb;--blu-bg:#eff6ff;--blu-b:#bfdbfe;
  --red:#dc2626;--red-bg:#fff1f2;--red-b:#fecaca;
  --amb:#d97706;--amb-bg:#fffbeb;--amb-b:#fde68a;
  --pur:#7c3aed;--pur-bg:#f5f3ff;--pur-b:#ddd6fe;
  --r:10px;--rsm:7px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans','Segoe UI',sans-serif;background:#f1f5f9;color:var(--text);font-size:14px;line-height:1.6;min-height:100vh;}

/* SCREENS */
.screen{display:none;min-height:100vh;}
.screen.active{display:flex;flex-direction:column;}
#s-login{align-items:center;justify-content:center;background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);}

/* LOGIN */
.login-box{background:#fff;border-radius:16px;padding:32px;width:420px;max-width:95vw;box-shadow:0 24px 80px rgba(0,0,0,.4);}
.login-logo{text-align:center;margin-bottom:20px;}
.login-logo h1{font-size:24px;font-weight:700;color:var(--c1);}
.login-logo span{color:var(--blu);font-size:12px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;}
.fl{display:block;font-size:11px;font-weight:700;color:var(--muted);margin-bottom:4px;margin-top:12px;text-transform:uppercase;letter-spacing:.06em;}
.fi{width:100%;font-family:inherit;font-size:14px;padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;color:var(--text);background:#fff;transition:border .15s;}
.fi:focus{outline:none;border-color:var(--blu);}
select.fi{cursor:pointer;}
.btn{border:none;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--blu);color:#fff;width:100%;justify-content:center;margin-top:16px;font-size:14px;padding:12px;}
.btn-primary:hover{background:#1d4ed8;}
.btn-ghost{background:var(--surf);color:var(--muted);border:1px solid var(--border);}
.btn-ghost:hover{background:#fff;border-color:#94a3b8;}
.btn-green{background:var(--grn);color:#fff;}.btn-green:hover{background:#15803d;}
.btn-red{background:var(--red);color:#fff;}.btn-red:hover{background:#b91c1c;}
.btn-amber{background:var(--amb);color:#fff;}.btn-amber:hover{background:#b45309;}
.btn-sm{padding:5px 12px;font-size:12px;border-radius:6px;}
.err{color:var(--red);font-size:12px;margin-top:8px;display:none;}

/* NAV */
.nav{background:var(--c1);padding:0 16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;box-shadow:0 2px 10px rgba(0,0,0,.3);position:sticky;top:0;z-index:100;}
.nav-brand{display:flex;align-items:center;gap:10px;padding:10px 0;}
.nav-brand h1{font-size:15px;font-weight:600;color:#fff;}
.nav-tabs{display:flex;gap:0;}
.nav-tab{padding:14px 18px;font-size:13px;font-weight:500;cursor:pointer;border:none;background:none;color:var(--c5);border-bottom:3px solid transparent;font-family:inherit;transition:all .15s;white-space:nowrap;}
.nav-tab:hover{color:#fff;}
.nav-tab.active{color:#fff;border-bottom-color:var(--blu);}
.nav-right{display:flex;align-items:center;gap:8px;padding:8px 0;}
.user-badge{font-size:12px;color:var(--c5);display:flex;align-items:center;gap:5px;}
.store-badge{font-size:11px;color:#4ade80;font-family:'DM Mono',monospace;}

/* PAGE */
.page-wrap{flex:1;max-width:1200px;width:100%;margin:0 auto;padding:20px 16px 60px;}
.page-title{font-size:20px;font-weight:600;margin-bottom:4px;}
.page-sub{font-size:13px;color:var(--muted);margin-bottom:20px;}
.card{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;margin-bottom:14px;}
.card-title{font-size:14px;font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:7px;}
.sec-lbl{font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}

/* STATUS BADGES */
.status{display:inline-flex;align-items:center;font-size:11px;font-weight:600;padding:2px 9px;border-radius:20px;white-space:nowrap;}
.st-pending{background:#fef3c7;color:#92400e;}
.st-approved{background:#dbeafe;color:#1e3a5f;}
.st-delivered{background:#dcfce7;color:#14532d;}
.st-cancelled{background:#fee2e2;color:#991b1b;}
.st-delayed{background:#f3e8ff;color:#4c1d95;}

/* TABLE */
.tbl-wrap{overflow-x:auto;border-radius:var(--rsm);border:1px solid var(--border);}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead{background:var(--surf);}
th{padding:9px 12px;text-align:left;font-size:11px;font-weight:600;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap;}
td{padding:9px 12px;border-bottom:1px solid var(--border);vertical-align:top;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--surf);}

/* METRICS */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px;}
@media(max-width:700px){.metrics{grid-template-columns:repeat(2,1fr);}}
.metric{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;text-align:center;}
.metric-val{font-size:28px;font-weight:700;font-family:'DM Mono',monospace;margin-bottom:3px;}
.metric-lbl{font-size:11px;color:var(--muted);}

/* FORM GRID */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:600px){.form-grid{grid-template-columns:1fr;}}
.form-grid .full{grid-column:1/-1;}
.form-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:16px;flex-wrap:wrap;}

/* FILTER BAR */
.filter-bar{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:14px;}
.filter-btn{border:1px solid var(--border);background:#fff;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:500;cursor:pointer;font-family:inherit;color:var(--muted);transition:.15s;}
.filter-btn.active{background:var(--c1);color:#fff;border-color:var(--c1);}
.filter-inp{font-family:inherit;font-size:12px;padding:5px 10px;border:1px solid var(--border);border-radius:6px;width:160px;}

/* DOCS */
.doc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
@media(max-width:700px){.doc-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:480px){.doc-grid{grid-template-columns:1fr;}}
.doc-card{border:1px solid var(--border);border-radius:var(--r);padding:14px;cursor:pointer;transition:.15s;display:flex;flex-direction:column;gap:6px;}
.doc-card:hover{border-color:var(--blu);background:var(--blu-bg);}
.doc-icon{font-size:24px;}
.doc-title{font-size:13px;font-weight:500;}
.doc-cat{font-size:11px;color:var(--muted);}

/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center;}
.modal-bg.open{display:flex;}
.modal{background:#fff;border-radius:14px;padding:22px;width:500px;max-width:95vw;max-height:90vh;overflow-y:auto;}
.modal h3{font-size:16px;font-weight:600;margin-bottom:4px;}
.modal-sub{font-size:12px;color:var(--muted);margin-bottom:16px;}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:16px;}

/* TOAST */
.toast{position:fixed;bottom:20px;right:20px;padding:8px 18px;border-radius:40px;font-size:12px;font-weight:600;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;color:#fff;}
.toast.show{opacity:1;}

/* PIN screen inside portal */
.pin-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center;}
.pin-overlay.open{display:flex;}
.pin-box{background:#fff;border-radius:14px;padding:26px;width:300px;text-align:center;}
.pin-box h3{font-size:16px;font-weight:600;margin-bottom:6px;}
.pin-box p{font-size:12px;color:var(--muted);margin-bottom:14px;}
.pin-inp{width:100%;font-size:22px;font-family:'DM Mono',monospace;text-align:center;padding:10px;border:1.5px solid var(--border);border-radius:8px;letter-spacing:.3em;}

/* IFRAME for bulletin */
.bul-frame{width:100%;height:calc(100vh - 120px);border:none;border-radius:var(--r);}

/* Empty state */
.empty{text-align:center;padding:40px 20px;color:var(--muted);}
.empty-icon{font-size:36px;margin-bottom:8px;}
.empty-title{font-size:15px;font-weight:500;margin-bottom:4px;}
.empty-sub{font-size:13px;}

@media(max-width:640px){
  .nav-tabs{overflow-x:auto;-webkit-overflow-scrolling:touch;}
  .nav-tab{padding:12px 14px;font-size:12px;}
  .page-wrap{padding:14px 12px 60px;}
}
</style>
</head>
<body>

<div class="toast" id="toast"></div>

<!-- ══ LOGIN SCREEN ══════════════════════════════════════════════ -->
<div id="s-login" class="screen active">
  <div class="login-box">
    <div class="login-logo">
      <h1>🏷 ТЕМАКС Портал</h1>
      <span>Вътрешна платформа</span>
    </div>
    <label class="fl">Твоето три имена</label>
    <input class="fi" id="l-name" placeholder="Иван Петров Иванов" onkeydown="if(event.key==='Enter')doLogin()">
    <label class="fl">Магазин / Обект</label>
    <select class="fi" id="l-store">
      <option value="">-- Избери магазин --</option>
      <option value="Централен офис">Централен офис</option>
    </select>
    <div class="err" id="l-err">Попълни всички полета.</div>
    <button class="btn btn-primary" onclick="doLogin()">Влез в портала →</button>
    <div style="text-align:center;margin-top:12px;">
      <button class="btn btn-ghost btn-sm" onclick="showPin()">🔐 Администратор</button>
    </div>
  </div>
</div>

<!-- ══ MAIN APP ══════════════════════════════════════════════════ -->
<div id="s-app" class="screen">

  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-brand">
      <h1>🏷 ТЕМАКС</h1>
    </div>
    <div class="nav-tabs">
      <button class="nav-tab active" onclick="showModule('transport')">🚚 Транспортни заявки</button>
      <button class="nav-tab" onclick="showModule('bulletin')">📋 Бюлетин</button>
      <button class="nav-tab" onclick="showModule('docs')">📁 Инструкции</button>
      <button class="nav-tab admin-only" onclick="showModule('admin')" style="display:none;">⚙ Администрация</button>
    </div>
    <div class="nav-right">
      <div class="user-badge">
        <span>👤</span>
        <span id="nav-name">...</span>
        <span class="store-badge" id="nav-store">...</span>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="doLogout()">Изход</button>
    </div>
  </nav>

  <!-- ── TRANSPORT MODULE ───────────────────────────────────── -->
  <div id="mod-transport" class="page-wrap">
    <div class="page-title">🚚 Транспортни заявки</div>
    <div class="page-sub">Подай заявка за доставка до клиент.</div>

    <!-- Metrics (admin only) -->
    <div id="tr-metrics" class="metrics" style="display:none;">
      <div class="metric"><div class="metric-val" id="m-total">0</div><div class="metric-lbl">Общо заявки</div></div>
      <div class="metric"><div class="metric-val" style="color:var(--amb);" id="m-pending">0</div><div class="metric-lbl">Изчакват</div></div>
      <div class="metric"><div class="metric-val" style="color:var(--grn);" id="m-done">0</div><div class="metric-lbl">Изпълнени</div></div>
      <div class="metric"><div class="metric-val" style="color:var(--red);" id="m-cancel">0</div><div class="metric-lbl">Отказани</div></div>
    </div>

    <!-- New order button -->
    <div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
      <button class="btn btn-green" onclick="openOrderModal()">+ Нова заявка</button>
    </div>

    <!-- Filter bar (admin) -->
    <div id="tr-filters" class="filter-bar" style="display:none;">
      <button class="filter-btn active" onclick="filterOrders('all',this)">Всички</button>
      <button class="filter-btn" onclick="filterOrders('pending',this)">Изчаква</button>
      <button class="filter-btn" onclick="filterOrders('approved',this)">Одобрена</button>
      <button class="filter-btn" onclick="filterOrders('delivered',this)">Изпълнена</button>
      <button class="filter-btn" onclick="filterOrders('cancelled',this)">Отказана</button>
      <button class="filter-btn" onclick="filterOrders('delayed',this)">Отложена</button>
      <input class="filter-inp" id="tr-search" placeholder="Търси..." oninput="renderOrders()">
    </div>

    <div class="card" style="padding:0;">
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Дата / Час</th>
              <th>Магазин</th>
              <th>Клиент</th>
              <th>Телефон</th>
              <th>Продукт</th>
              <th>Кол.</th>
              <th>Адрес</th>
              <th>Статус</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody id="tr-body">
            <tr><td colspan="10" style="text-align:center;padding:30px;color:var(--muted);">Зареждане...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ── BULLETIN MODULE ────────────────────────────────────── -->
  <div id="mod-bulletin" class="page-wrap" style="display:none;padding:0;">
    <iframe class="bul-frame" src="https://tenchotenev13-afk.github.io/--buletin/" title="Т-Бюлетин"></iframe>
  </div>

  <!-- ── DOCS MODULE ────────────────────────────────────────── -->
  <div id="mod-docs" class="page-wrap" style="display:none;">
    <div class="page-title">📁 Инструкции & Документи</div>
    <div class="page-sub">Процедури, наредби и полезни ресурси.</div>

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:8px;">
      <div class="filter-bar" style="margin:0;">
        <button class="filter-btn active" onclick="filterDocs('all',this)">Всички</button>
        <button class="filter-btn" onclick="filterDocs('SAP',this)">SAP</button>
        <button class="filter-btn" onclick="filterDocs('Процедури',this)">Процедури</button>
        <button class="filter-btn" onclick="filterDocs('Обучения',this)">Обучения</button>
        <button class="filter-btn" onclick="filterDocs('Формуляри',this)">Формуляри</button>
      </div>
      <button class="btn btn-green btn-sm admin-only" onclick="openDocModal()" style="display:none;">+ Добави документ</button>
    </div>

    <div class="doc-grid" id="doc-grid">
      <div class="empty" style="grid-column:1/-1;">
        <div class="empty-icon">📁</div>
        <div class="empty-title">Няма документи</div>
        <div class="empty-sub">Администраторът може да добави инструкции и документи.</div>
      </div>
    </div>
  </div>

  <!-- ── ADMIN MODULE ───────────────────────────────────────── -->
  <div id="mod-admin" class="page-wrap" style="display:none;">
    <div class="page-title">⚙ Администрация</div>
    <div class="page-sub">Управление на магазини, получатели и настройки.</div>

    <div class="card">
      <div class="card-title">🏪 Магазини</div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>Магазин</th><th>Град</th><th>Действия</th></tr></thead>
          <tbody id="stores-body"><tr><td colspan="3" style="text-align:center;padding:20px;color:var(--muted);">Зареждане...</td></tr></tbody>
        </table>
      </div>
      <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
        <input class="fi" id="new-store-name" placeholder="Название на магазина" style="flex:2;min-width:150px;">
        <input class="fi" id="new-store-city" placeholder="Град" style="flex:1;min-width:100px;">
        <button class="btn btn-green btn-sm" onclick="addStore()">+ Добави</button>
      </div>
    </div>

    <div class="card">
      <div class="card-title">🔐 Смени PIN</div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input type="password" class="fi" id="new-pin" placeholder="Нов PIN (4-6 цифри)" style="flex:1;max-width:200px;">
        <button class="btn btn-amber btn-sm" onclick="changePin()">Смени PIN</button>
      </div>
    </div>
  </div>

</div>

<!-- ══ MODALS ════════════════════════════════════════════════════ -->

<!-- New Order Modal -->
<div class="modal-bg" id="order-modal">
  <div class="modal">
    <h3>🚚 Нова транспортна заявка</h3>
    <div class="modal-sub">Попълни данните за доставката до клиента.</div>
    <div class="form-grid">
      <div>
        <label class="fl">Дата *</label>
        <input type="date" class="fi" id="o-date">
      </div>
      <div>
        <label class="fl">Час *</label>
        <input type="time" class="fi" id="o-hour">
      </div>
      <div>
        <label class="fl">Номер на бон</label>
        <input class="fi" id="o-bon" placeholder="напр. 000123">
      </div>
      <div>
        <label class="fl">Магазин</label>
        <input class="fi" id="o-store" readonly style="background:var(--surf);">
      </div>
      <div>
        <label class="fl">Три имена на клиента *</label>
        <input class="fi" id="o-name" placeholder="Иван Петров Иванов">
      </div>
      <div>
        <label class="fl">Телефон *</label>
        <input class="fi" id="o-phone" placeholder="0888 000 000">
      </div>
      <div>
        <label class="fl">Продукт *</label>
        <input class="fi" id="o-product" placeholder="напр. Диван Comfort 3+2">
      </div>
      <div>
        <label class="fl">Цвят / Модел</label>
        <input class="fi" id="o-color" placeholder="напр. Бежово">
      </div>
      <div>
        <label class="fl">Количество</label>
        <input type="number" class="fi" id="o-qty" value="1" min="1">
      </div>
      <div>
        <label class="fl">Агент (обработва)</label>
        <input class="fi" id="o-agent" placeholder="напр. Мария Иванова">
      </div>
      <div class="full">
        <label class="fl">Адрес за доставка *</label>
        <input class="fi" id="o-addr" placeholder="гр. Варна, ул. Примерна 1, ет. 3">
      </div>
      <div class="full">
        <label class="fl">Бележки</label>
        <input class="fi" id="o-notes" placeholder="Допълнителна информация...">
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal('order-modal')">Откажи</button>
      <button class="btn btn-green" onclick="submitOrder()">✓ Подай заявката</button>
    </div>
  </div>
</div>

<!-- Status change modal (admin) -->
<div class="modal-bg" id="status-modal">
  <div class="modal">
    <h3>Промени статус</h3>
    <div class="modal-sub" id="status-modal-info">Заявка #...</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;">
      <button class="btn" style="background:#fef3c7;color:#92400e;" onclick="setStatus('pending')">⏳ Изчаква</button>
      <button class="btn" style="background:#dbeafe;color:#1e3a5f;" onclick="setStatus('approved')">✓ Одобрена</button>
      <button class="btn btn-green" onclick="setStatus('delivered')">✅ Изпълнена</button>
      <button class="btn" style="background:#f3e8ff;color:#4c1d95;" onclick="setStatus('delayed')">⏱ Отложена</button>
      <button class="btn btn-red" style="grid-column:1/-1;" onclick="setStatus('cancelled')">✕ Отказана</button>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal('status-modal')">Затвори</button>
    </div>
  </div>
</div>

<!-- Doc modal (admin) -->
<div class="modal-bg" id="doc-modal">
  <div class="modal">
    <h3>+ Добави документ</h3>
    <label class="fl">Заглавие</label>
    <input class="fi" id="d-title" placeholder="напр. Процедура за ревизии">
    <label class="fl">Категория</label>
    <select class="fi" id="d-cat">
      <option>SAP</option><option>Процедури</option>
      <option>Обучения</option><option>Формуляри</option><option>Друго</option>
    </select>
    <label class="fl">Линк (URL)</label>
    <input class="fi" id="d-url" placeholder="https://...">
    <label class="fl">Описание</label>
    <input class="fi" id="d-desc" placeholder="Кратко описание">
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal('doc-modal')">Откажи</button>
      <button class="btn btn-green" onclick="submitDoc()">+ Добави</button>
    </div>
  </div>
</div>

<!-- PIN overlay -->
<div class="pin-overlay" id="pin-overlay">
  <div class="pin-box">
    <h3>🔐 Администратор</h3>
    <p>Въведи PIN за административен достъп.</p>
    <input type="password" class="pin-inp" id="pin-inp" maxlength="6" placeholder="••••" onkeydown="if(event.key==='Enter')checkPin()">
    <div style="display:flex;gap:8px;margin-top:12px;">
      <button class="btn btn-ghost" style="flex:1;" onclick="closeModal('pin-overlay')">Откажи</button>
      <button class="btn btn-primary" style="flex:2;margin-top:0;" onclick="checkPin()">Влез</button>
    </div>
    <p style="color:var(--red);font-size:12px;margin-top:8px;display:none;" id="pin-err">Грешен PIN</p>
  </div>
</div>

<script>

const SB_URL = 'https://xiwkdiqqplgdcrkewgtv.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inhpd2tkaXFxcGxnZGNya2V3Z3R2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk1NTA5MjYsImV4cCI6MjA5NTEyNjkyNn0.aOlvvQI6x5wS60iH7rMDD7j_Go9FMP1YkWrLnfeL0CA';
const BULETIN_URL = 'https://tenchotenev13-afk.github.io/--buletin/';
var sb = null;
var isAdmin = false;
var currentUser = null;
var currentStore = null;
var orders = [];
var stores = [];
var docs = [];
var _orderFilter = 'all';
var _docFilter = 'all';
var _statusOrderId = null;

// ── UTILS ────────────────────────────────────────────────────────────────────
function esc(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function fmt(d){if(!d)return'—';var dt=new Date(d);return dt.toLocaleDateString('bg-BG')+'  '+dt.toLocaleTimeString('bg-BG',{hour:'2-digit',minute:'2-digit'});}
function today(){return new Date().toISOString().slice(0,10);}
function nowTime(){var d=new Date();return d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0');}
function toast(msg,c){var t=document.getElementById('toast');t.textContent=msg;t.style.background=c||'#16a34a';t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2500);}
function closeModal(id){document.getElementById(id).classList.remove('open');}
function statusBadge(s){var m={pending:'⏳ Изчаква',approved:'✓ Одобрена',delivered:'✅ Изпълнена',cancelled:'✕ Отказана',delayed:'⏱ Отложена'};var cls={pending:'st-pending',approved:'st-approved',delivered:'st-delivered',cancelled:'st-cancelled',delayed:'st-delayed'};return '<span class="status '+( cls[s]||'st-pending')+'">'+esc(m[s]||s)+'</span>';}

// ── LOGIN ────────────────────────────────────────────────────────────────────
async function init(){
  sb = supabase.createClient(SB_URL, SB_KEY);
  // Load stores for dropdown
  var {data} = await sb.from('stores').select('*').eq('active',true).order('name');
  stores = data || [];
  var sel = document.getElementById('l-store');
  stores.forEach(function(s){
    var opt = document.createElement('option');
    opt.value = s.name; opt.textContent = s.name;
    sel.appendChild(opt);
  });
  // Check if already logged in
  var saved = localStorage.getItem('tb_portal_user');
  if(saved){
    try{
      var u = JSON.parse(saved);
      currentUser = u.name; currentStore = u.store;
      isAdmin = localStorage.getItem('tb_is_admin') === '1';
      startApp();
    }catch(e){}
  }
}

function doLogin(){
  var name = document.getElementById('l-name').value.trim();
  var store = document.getElementById('l-store').value;
  var err = document.getElementById('l-err');
  if(!name||!store){err.style.display='block';return;}
  err.style.display='none';
  currentUser = name; currentStore = store;
  localStorage.setItem('tb_portal_user', JSON.stringify({name:name,store:store}));
  localStorage.setItem('tb_name', name);
  startApp();
}

function doLogout(){
  localStorage.removeItem('tb_portal_user');
  localStorage.removeItem('tb_is_admin');
  isAdmin = false; currentUser = null; currentStore = null;
  document.getElementById('s-login').classList.add('active');
  document.getElementById('s-app').classList.remove('active');
}

function startApp(){
  document.getElementById('s-login').classList.remove('active');
  document.getElementById('s-app').classList.add('active');
  document.getElementById('nav-name').textContent = currentUser;
  document.getElementById('nav-store').textContent = currentStore;
  // Show admin UI
  if(isAdmin){
    document.querySelectorAll('.admin-only').forEach(function(el){el.style.display='';el.style.removeProperty('display');el.style.display='inline-flex';});
    document.getElementById('tr-metrics').style.display='grid';
    document.getElementById('tr-filters').style.display='flex';
  }
  loadOrders();
  loadDocs();
  showModule('transport');
}

// ── MODULES ──────────────────────────────────────────────────────────────────
function showModule(mod){
  ['transport','bulletin','docs','admin'].forEach(function(m){
    document.getElementById('mod-'+m).style.display = m===mod ? '' : 'none';
  });
  document.querySelectorAll('.nav-tab').forEach(function(t){t.classList.remove('active');});
  var tabs = {'transport':0,'bulletin':1,'docs':2,'admin':3};
  var tabEls = document.querySelectorAll('.nav-tab');
  if(tabEls[tabs[mod]]) tabEls[tabs[mod]].classList.add('active');
  if(mod==='admin') loadStoresAdmin();
}

// ── TRANSPORT ORDERS ──────────────────────────────────────────────────────────
async function loadOrders(){
  var query = sb.from('transport_orders').select('*').order('created_at',{ascending:false});
  if(!isAdmin) query = query.eq('store_name', currentStore);
  var {data,error} = await query;
  if(error){console.error(error);return;}
  orders = data || [];
  renderOrders();
  updateMetrics();
  // Real-time
  sb.channel('transport').on('postgres_changes',{event:'*',schema:'public',table:'transport_orders'},function(){loadOrders();}).subscribe();
}

function updateMetrics(){
  document.getElementById('m-total').textContent = orders.length;
  document.getElementById('m-pending').textContent = orders.filter(function(o){return o.status==='pending';}).length;
  document.getElementById('m-done').textContent = orders.filter(function(o){return o.status==='delivered';}).length;
  document.getElementById('m-cancel').textContent = orders.filter(function(o){return o.status==='cancelled';}).length;
}

function renderOrders(){
  var search = (document.getElementById('tr-search')||{}).value||'';
  var list = orders.filter(function(o){
    if(_orderFilter!=='all' && o.status!==_orderFilter) return false;
    if(search){
      var q = search.toLowerCase();
      return (o.customer_name||'').toLowerCase().includes(q) ||
             (o.product||'').toLowerCase().includes(q) ||
             (o.store_name||'').toLowerCase().includes(q) ||
             (o.phone||'').includes(q);
    }
    return true;
  });
  var body = document.getElementById('tr-body');
  if(!list.length){
    body.innerHTML = '<tr><td colspan="10"><div class="empty"><div class="empty-icon">🚚</div><div class="empty-title">Няма заявки</div><div class="empty-sub">Натисни "+ Нова заявка" за да подадеш.</div></div></td></tr>';
    return;
  }
  body.innerHTML = list.map(function(o,i){
    var acts = isAdmin
      ? '<button class="btn btn-ghost btn-sm" onclick="openStatusModal(\''+o.id+'\',\''+esc(o.customer_name||'')+'\')">Статус</button>'
      : '';
    return '<tr><td style="font-family:monospace;font-size:11px;color:var(--muted);">'+(i+1)+'</td>'+
      '<td><div style="font-weight:500;">'+esc(o.date||'')+'</div><div style="font-size:11px;color:var(--muted);">'+esc(o.hour||'')+'</div></td>'+
      '<td><span style="font-size:11px;background:var(--surf);border:1px solid var(--border);padding:2px 7px;border-radius:20px;">'+esc(o.store_name||'')+'</span></td>'+
      '<td><div style="font-weight:500;">'+esc(o.customer_name||'')+'</div><div style="font-size:11px;color:var(--muted);">Бон: '+esc(o.bon||'—')+'</div></td>'+
      '<td style="font-family:monospace;font-size:12px;">'+esc(o.phone||'')+'</td>'+
      '<td><div>'+esc(o.product||'')+'</div><div style="font-size:11px;color:var(--muted);">'+esc(o.color||'')+'</div></td>'+
      '<td style="text-align:center;font-weight:600;">'+esc(String(o.qty||1))+'</td>'+
      '<td style="font-size:12px;max-width:160px;">'+esc(o.address||'')+'</td>'+
      '<td>'+statusBadge(o.status||'pending')+'</td>'+
      '<td>'+acts+'</td></tr>';
  }).join('');
}

function filterOrders(f, btn){
  _orderFilter = f;
  document.querySelectorAll('.filter-btn').forEach(function(b){b.classList.remove('active');});
  if(btn) btn.classList.add('active');
  renderOrders();
}

function openOrderModal(){
  document.getElementById('o-date').value = today();
  document.getElementById('o-hour').value = nowTime();
  document.getElementById('o-bon').value = '';
  document.getElementById('o-store').value = currentStore;
  document.getElementById('o-name').value = '';
  document.getElementById('o-phone').value = '';
  document.getElementById('o-product').value = '';
  document.getElementById('o-color').value = '';
  document.getElementById('o-qty').value = '1';
  document.getElementById('o-agent').value = currentUser;
  document.getElementById('o-addr').value = '';
  document.getElementById('o-notes').value = '';
  document.getElementById('order-modal').classList.add('open');
}

async function submitOrder(){
  var name = document.getElementById('o-name').value.trim();
  var phone = document.getElementById('o-phone').value.trim();
  var product = document.getElementById('o-product').value.trim();
  var addr = document.getElementById('o-addr').value.trim();
  if(!name||!phone||!product||!addr){toast('Попълни задължителните полета *','#dc2626');return;}
  var order = {
    store_name: currentStore,
    date: document.getElementById('o-date').value,
    hour: document.getElementById('o-hour').value,
    bon: document.getElementById('o-bon').value.trim(),
    customer_name: name,
    phone: phone,
    product: product,
    color: document.getElementById('o-color').value.trim(),
    qty: parseInt(document.getElementById('o-qty').value)||1,
    address: addr,
    agent: document.getElementById('o-agent').value.trim(),
    notes: document.getElementById('o-notes').value.trim(),
    status: 'pending'
  };
  var {error} = await sb.from('transport_orders').insert(order);
  if(error){toast('Грешка: '+error.message,'#dc2626');return;}
  closeModal('order-modal');
  toast('✓ Заявката е подадена успешно!');
  loadOrders();
}

function openStatusModal(id, name){
  _statusOrderId = id;
  document.getElementById('status-modal-info').textContent = 'Клиент: '+name;
  document.getElementById('status-modal').classList.add('open');
}

async function setStatus(status){
  if(!_statusOrderId)return;
  var {error} = await sb.from('transport_orders').update({status:status, updated_at: new Date().toISOString()}).eq('id',_statusOrderId);
  if(error){toast('Грешка: '+error.message,'#dc2626');return;}
  closeModal('status-modal');
  toast('✓ Статусът е обновен');
  loadOrders();
}

// ── DOCUMENTS ────────────────────────────────────────────────────────────────
async function loadDocs(){
  var {data} = await sb.from('documents').select('*').order('created_at',{ascending:false});
  docs = data || [];
  renderDocs();
}

function renderDocs(){
  var list = docs.filter(function(d){return _docFilter==='all'||d.category===_docFilter;});
  var grid = document.getElementById('doc-grid');
  if(!list.length){
    grid.innerHTML = '<div class="empty" style="grid-column:1/-1;"><div class="empty-icon">📁</div><div class="empty-title">Няма документи в тази категория</div></div>';
    return;
  }
  var icons = {SAP:'🖥',Процедури:'📋',Обучения:'🎓',Формуляри:'📝',Друго:'📄'};
  grid.innerHTML = list.map(function(d){
    return '<div class="doc-card" onclick="window.open(''+d.url+'','_blank')">'+
      '<div class="doc-icon">'+(icons[d.category]||'📄')+'</div>'+
      '<div class="doc-title">'+esc(d.title||'')+'</div>'+
      '<div class="doc-cat">'+esc(d.category||'')+'</div>'+
      (d.description?'<div style="font-size:11px;color:var(--muted);">'+esc(d.description)+'</div>':'')+
      '</div>';
  }).join('');
}

function filterDocs(f,btn){
  _docFilter=f;
  document.querySelectorAll('.filter-btn').forEach(function(b){b.classList.remove('active');});
  if(btn)btn.classList.add('active');
  renderDocs();
}

function openDocModal(){document.getElementById('doc-modal').classList.add('open');}

async function submitDoc(){
  var title=document.getElementById('d-title').value.trim();
  var url=document.getElementById('d-url').value.trim();
  if(!title||!url){toast('Въведи заглавие и линк','#dc2626');return;}
  var {error} = await sb.from('documents').insert({
    title:title, category:document.getElementById('d-cat').value,
    url:url, description:document.getElementById('d-desc').value.trim()
  });
  if(error){toast('Грешка: '+error.message,'#dc2626');return;}
  closeModal('doc-modal');toast('✓ Документът е добавен');loadDocs();
}

// ── ADMIN ────────────────────────────────────────────────────────────────────
async function loadStoresAdmin(){
  var {data} = await sb.from('stores').select('*').order('name');
  stores = data||[];
  var body = document.getElementById('stores-body');
  if(!stores.length){body.innerHTML='<tr><td colspan="3" style="text-align:center;padding:20px;color:var(--muted);">Няма магазини.</td></tr>';return;}
  body.innerHTML = stores.map(function(s){
    return '<tr><td style="font-weight:500;">'+esc(s.name)+'</td><td>'+esc(s.city||'')+'</td>'+
      '<td><button class="btn btn-ghost btn-sm" onclick="deleteStore(\''+s.id+'\')">Изтрий</button></td></tr>';
  }).join('');
}

async function addStore(){
  var name=document.getElementById('new-store-name').value.trim();
  var city=document.getElementById('new-store-city').value.trim();
  if(!name){toast('Въведи название','#dc2626');return;}
  var {error} = await sb.from('stores').insert({name:name,city:city});
  if(error){toast('Грешка: '+error.message,'#dc2626');return;}
  document.getElementById('new-store-name').value='';
  document.getElementById('new-store-city').value='';
  toast('✓ Магазинът е добавен');loadStoresAdmin();
}

async function deleteStore(id){
  if(!confirm('Изтрий магазина?'))return;
  await sb.from('stores').delete().eq('id',id);
  toast('✓ Изтрит');loadStoresAdmin();
}

function changePin(){
  var pin=document.getElementById('new-pin').value.trim();
  if(!/^\d{4,6}$/.test(pin)){toast('PIN трябва да е 4-6 цифри','#dc2626');return;}
  localStorage.setItem('tb_pin',pin);
  document.getElementById('new-pin').value='';
  toast('✓ PIN е сменен');
}

// ── PIN ──────────────────────────────────────────────────────────────────────
function showPin(){
  document.getElementById('pin-inp').value='';
  document.getElementById('pin-err').style.display='none';
  document.getElementById('pin-overlay').classList.add('open');
  setTimeout(function(){document.getElementById('pin-inp').focus();},100);
}

function checkPin(){
  var pin=document.getElementById('pin-inp').value;
  var saved=localStorage.getItem('tb_pin')||'1234';
  if(pin===saved){
    isAdmin=true;
    localStorage.setItem('tb_is_admin','1');
    closeModal('pin-overlay');
    // If not logged in yet — just close
    if(!currentUser){toast('✓ Администраторски достъп');return;}
    // Show admin elements
    document.querySelectorAll('.admin-only').forEach(function(el){el.style.display='inline-flex';});
    document.getElementById('tr-metrics').style.display='grid';
    document.getElementById('tr-filters').style.display='flex';
    loadOrders();toast('✓ Администраторски достъп');
  } else {
    document.getElementById('pin-err').style.display='block';
  }
}

// Close modals on backdrop click
document.addEventListener('click',function(e){
  if(e.target.classList.contains('modal-bg')||e.target.classList.contains('pin-overlay'))
    e.target.classList.remove('open');
});

// ── START ────────────────────────────────────────────────────────────────────
init();

</script>
</body>
</html>
